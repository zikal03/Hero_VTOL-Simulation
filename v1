    <!-- ===================== -->
    <!-- ArduPilot interface    -->
    <!-- ===================== -->
    <!--
      Channel assignment summary (ArduPilot VTOL Quad-Plane frame):
        ch0 (SERVO1): Left elevon   — POSITION
        ch1 (SERVO2): Right elevon  — POSITION
        ch2 (SERVO3): Pusher motor  — VELOCITY (throttle)
        ch3 (SERVO4): Left aileron  — POSITION (multiplier negative for differential)
        ch3 (SERVO4): Right aileron — POSITION (same channel, opposite multiplier sign)
        ch4 (SERVO5): Motor1 Front-Right = rotor_2, CCW → multiplier -1500
        ch5 (SERVO6): Motor2 Rear-Left   = rotor_1, CCW → multiplier -1500
        ch6 (SERVO7): Motor3 Front-Left  = rotor_0, CW  → multiplier +1500
        ch7 (SERVO8): Motor4 Rear-Right  = rotor_3, CW  → multiplier +1500

      Spin direction convention (viewed from above, standard X-frame):
        Front-Left  (rotor_0): CW  (+)
        Front-Right (rotor_2): CCW (-)
        Rear-Left   (rotor_1): CCW (-)
        Rear-Right  (rotor_3): CW  (+)
    -->
    <plugin name="ArduPilotPlugin" filename="ArduPilotPlugin">
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9002</fdm_port_in>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <lock_step>1</lock_step>

      <!-- 180-deg roll aligns Gazebo body axes (X-fwd, Z-up) to
           ArduPilot airframe (X-fwd, Z-down). The extra 90-deg yaw
           maps Gazebo ENU to ArduPilot NED. -->
      <modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 180 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>

      <imuName>imu_sensor</imuName>

      <!-- ch0: Left elevon (SERVO1 → SERVO1_FUNCTION 77 Elevon Left) -->
      <control channel="0">
        <jointName>left_elevon_joint</jointName>
        <useForce>1</useForce>
        <multiplier>1.048</multiplier>
        <offset>-0.5</offset>
        <servo_min>1100</servo_min>
        <servo_max>1900</servo_max>
        <type>POSITION</type>
        <p_gain>10.0</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch1: Right elevon (SERVO2 → SERVO2_FUNCTION 78 Elevon Right) -->
      <control channel="1">
        <jointName>right_elevon_joint</jointName>
        <useForce>1</useForce>
        <multiplier>1.048</multiplier>
        <offset>-0.5</offset>
        <servo_min>1100</servo_min>
        <servo_max>1900</servo_max>
        <type>POSITION</type>
        <p_gain>10.0</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch2: Pusher motor (SERVO3 → throttle in fixed-wing mode) -->
      <control channel="2">
        <jointName>rotor_pusher_joint</jointName>
        <useForce>1</useForce>
        <multiplier>2000</multiplier>
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.20</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch3: Left aileron (SERVO4 → SERVO4_FUNCTION 4 Aileron) -->
      <!-- Left aileron deflects down when command is positive (negative multiplier) -->
      <control channel="3">
        <jointName>left_aileron_joint</jointName>
        <useForce>1</useForce>
        <multiplier>-0.872664626</multiplier>
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>POSITION</type>
        <p_gain>10.0</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch3: Right aileron (SERVO4 → same channel, opposite sign for differential) -->
      <control channel="3">
        <jointName>right_aileron_joint</jointName>
        <useForce>1</useForce>
        <multiplier>0.872664626</multiplier>
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>POSITION</type>
        <p_gain>10.0</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch4: Motor1 Front-Right = rotor_2 (CCW → negative multiplier) -->
      <control channel="4">
        <jointName>rotor_2_joint</jointName>
        <useForce>1</useForce>
        <multiplier>-1500</multiplier>
        <offset>0</offset>
        <servo_min>1100</servo_min>
        <servo_max>1900</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.20</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch5: Motor2 Rear-Left = rotor_1 (CCW → negative multiplier) -->
      <control channel="5">
        <jointName>rotor_1_joint</jointName>
        <useForce>1</useForce>
        <multiplier>-1500</multiplier>
        <offset>0</offset>
        <servo_min>1100</servo_min>
        <servo_max>1900</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.20</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0</d_gain>
        <i_max>0</i_max>
        <i_min>0</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch6: Motor3 Front-Left = rotor_0 (CW → positive multiplier) -->
      <control channel="6">
        <jointName>rotor_0_joint</jointName>
        <useForce>1</useForce>
        <multiplier>1500</multiplier>
        <offset>0</offset>
        <servo_min>1100</servo_min>
        <servo_max>1900</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.20</p_gain>
        <i_gain>0</i_gain>
        <d_gain>0</d_gain>
